# 环境配置
# dev=开发环境, test=测试环境, prod=生产环境
ENV=dev

# 数据库配置
# 格式：postgresql+psycopg://用户名:密码@主机:端口/数据库名
# 开发环境示例：postgresql+psycopg://postgres:postgres@localhost:5432/football_platform_dev
# 生产环境请使用强密码和专用数据库用户
DATABASE_URL=postgresql+psycopg://postgres:your-password@localhost:5432/football_platform_dev

# JWT 配置
# 生产环境必须使用强随机字符串，可用 openssl rand -hex 32 生成
SECRET_KEY=your-secret-key-here-change-in-production

# 应用配置
APP_NAME=Football Platform
DEBUG=True
